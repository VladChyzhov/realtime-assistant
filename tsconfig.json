{
    "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "moduleResolution": "node",   
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "allowJs": true,
      "noEmit": true,
      "forceConsistentCasingInFileNames": true,
      "jsx": "react-jsx"
    },
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js"
    ],
    "exclude": [
      "node_modules",
      "dist",
      "build",
      "out"
    ]
  }
  